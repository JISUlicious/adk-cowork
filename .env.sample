# Cowork environment configuration
# Copy this file to .env and edit. The repo-root .env is read by:
#   - the Python side via python-dotenv (config.py)
#   - the desktop app's dev loop via dotenvy (src-tauri/src/lib.rs)
# Release builds of the desktop app do NOT read it.

# --- Model endpoint (any OpenAI-compatible server) ---
# LM Studio:  http://localhost:1234/v1
# Ollama:     http://localhost:11434/v1
# vLLM:       http://localhost:8000/v1
# OpenRouter:  https://openrouter.ai/api/v1
COWORK_MODEL_BASE_URL="http://localhost:1234/v1"

# API key — use "lm-studio" or "ollama" for local servers that don't need auth
COWORK_MODEL_API_KEY="lm-studio"

# Model name as your endpoint expects it
COWORK_MODEL_NAME="qwen3-8b"

# --- Workspace ---
# Where projects, sessions, and skills are stored on disk
# COWORK_WORKSPACE_ROOT="~/CoworkWorkspaces"

# --- Dev server / web UI handshake ---
# Pin these for a zero-surprise dev loop. Both the FastAPI server
# (cowork_server/__main__.py) and the Vite proxy (cowork-web/vite.config.ts)
# read these from this file — set once here and everything lines up.
#
# In release (Tauri sidecar) mode the shell picks a random port and random
# token per launch and passes them to the webview via the COWORK_READY
# stdout handshake; the vars below have no effect there.
# COWORK_PORT=9100
# COWORK_TOKEN="cowork-local-dev-token"

# --- Desktop dev ---
# Point the Tauri sidecar at a system/venv interpreter instead of the
# bundled one under src-tauri/resources/python. Useful when you haven't
# run scripts/bundle_python.py, or the bundle is corrupted. Absolute
# path. The repo's .venv (created by `uv sync`) already has cowork-core
# and cowork-server installed in editable mode, so this usually works:
# COWORK_PYTHON="/absolute/path/to/cowork/.venv/bin/python"

# --- Email (SMTP) ---
# Required for email_send tool. email_draft works without SMTP.
# COWORK_SMTP_HOST="smtp.gmail.com"
# COWORK_SMTP_PORT="587"
# COWORK_SMTP_USER="you@gmail.com"
# COWORK_SMTP_PASSWORD="app-password-here"
# COWORK_SMTP_TLS="true"
# COWORK_EMAIL_FROM="you@gmail.com"
