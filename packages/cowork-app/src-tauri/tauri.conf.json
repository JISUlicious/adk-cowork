{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cowork",
  "version": "0.1.0",
  "identifier": "dev.cowork.app",
  "build": {
    "frontendDist": "../../cowork-web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../cowork-web run dev",
    "beforeBuildCommand": "npm --prefix ../cowork-web run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cowork",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "appimage", "msi", "nsis"],
    "resources": {
      "resources/python": "resources/python"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
